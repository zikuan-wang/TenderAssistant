<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:TenderAssistant.Client.Controls"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

    <Thickness x:Key="PageContentPadding">14,12,16,16</Thickness>

    <SolidColorBrush x:Key="TenderPrimaryBrush" Color="#1E4F8A" />
    <SolidColorBrush x:Key="TenderAccentBrush" Color="#00897B" />
    <SolidColorBrush x:Key="TenderDangerBrush" Color="#C62828" />
    <SolidColorBrush x:Key="TenderAppBackgroundBrush" Color="#F5F7FA" />
    <SolidColorBrush x:Key="TenderSurfaceBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="TenderSurfaceAltBrush" Color="#F6F8FB" />
    <SolidColorBrush x:Key="TenderStrokeBrush" Color="#D8E0EA" />
    <SolidColorBrush x:Key="TenderTextBrush" Color="#1F2937" />
    <SolidColorBrush x:Key="TenderSubtleTextBrush" Color="#667085" />
    <SolidColorBrush x:Key="TenderNavigationBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="TenderNavigationSelectedBrush" Color="#E8F1FF" />
    <SolidColorBrush x:Key="TenderNavigationHoverBrush" Color="#F2F6FC" />

    <Style x:Key="WorkspaceCardStyle" TargetType="{x:Type materialDesign:Card}">
        <Setter Property="Margin" Value="0,0,0,10" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="Background" Value="{DynamicResource TenderSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource TenderStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp1" />
    </Style>

    <Style x:Key="MetricCardStyle" TargetType="{x:Type materialDesign:Card}" BasedOn="{StaticResource WorkspaceCardStyle}">
        <Setter Property="MinHeight" Value="112" />
    </Style>

    <Style TargetType="{x:Type materialDesign:Card}" BasedOn="{StaticResource WorkspaceCardStyle}" />

    <Style x:Key="SectionTitleStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TenderPrimaryBrush}" />
        <Setter Property="Margin" Value="0,0,0,6" />
    </Style>

    <Style x:Key="SectionHintStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{DynamicResource TenderSubtleTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="Margin" Value="0,0,0,14" />
    </Style>

    <Style x:Key="ListItemBorderStyle" TargetType="{x:Type Border}">
        <Setter Property="Margin" Value="0,0,0,10" />
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Background" Value="{DynamicResource TenderSurfaceAltBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource TenderStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="NavigationListBoxItemStyle" TargetType="{x:Type ListBoxItem}">
        <Setter Property="Margin" Value="0,2" />
        <Setter Property="Padding" Value="10,9" />
        <Setter Property="Foreground" Value="{DynamicResource TenderTextBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                    <Border x:Name="Root"
                            Background="Transparent"
                            CornerRadius="10"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource TenderNavigationHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource TenderNavigationSelectedBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource TenderPrimaryBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ControlTemplate x:Key="MaterialProgressButtonTemplate" TargetType="{x:Type Button}">
        <Border x:Name="Root"
                MinHeight="{TemplateBinding MinHeight}"
                Padding="{TemplateBinding Padding}"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="6">
            <Grid>
                <ContentPresenter x:Name="ButtonContent"
                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                  RecognizesAccessKey="True" />
                <ProgressBar x:Name="ButtonProgress"
                             Width="18"
                             Height="18"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             IsIndeterminate="True"
                             Style="{StaticResource MaterialDesignCircularProgressBar}"
                             Visibility="Collapsed" />
            </Grid>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Root" Property="Opacity" Value="0.92" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Root" Property="Opacity" Value="0.84" />
            </Trigger>
            <DataTrigger Binding="{Binding Command.IsRunning, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                <Setter TargetName="ButtonContent" Property="Visibility" Value="Hidden" />
                <Setter TargetName="ButtonProgress" Property="Visibility" Value="Visible" />
            </DataTrigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Root" Property="Opacity" Value="0.46" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="MaterialPrimaryButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource MaterialDesignRaisedButton}">
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="Padding" Value="12,4" />
        <Setter Property="Background" Value="{DynamicResource TenderPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource TenderPrimaryBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Template" Value="{StaticResource MaterialProgressButtonTemplate}" />
    </Style>

    <Style x:Key="MaterialSecondaryButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="Padding" Value="12,4" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource TenderStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource TenderPrimaryBrush}" />
        <Setter Property="Template" Value="{StaticResource MaterialProgressButtonTemplate}" />
    </Style>

    <Style x:Key="MaterialDangerButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource MaterialDesignRaisedButton}">
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="Padding" Value="12,4" />
        <Setter Property="Background" Value="{DynamicResource TenderDangerBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource TenderDangerBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Template" Value="{StaticResource MaterialProgressButtonTemplate}" />
    </Style>

    <Style x:Key="MaterialTransparentButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource MaterialDesignToolButton}">
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource TenderPrimaryBrush}" />
        <Setter Property="Template" Value="{StaticResource MaterialProgressButtonTemplate}" />
    </Style>

    <Style TargetType="{x:Type Button}" BasedOn="{StaticResource MaterialSecondaryButtonStyle}" />

    <Style TargetType="{x:Type ToolTip}" BasedOn="{StaticResource MaterialDesignToolTip}" />

    <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
        <Setter Property="Margin" Value="0,4,0,0" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="ToolTip" Value="请填写或确认该项" />
        <Setter Property="materialDesign:HintAssist.FloatingScale" Value="0.74" />
        <Setter Property="materialDesign:HintAssist.IsFloating" Value="True" />
        <Setter Property="materialDesign:TextFieldAssist.HasClearButton" Value="True" />
    </Style>

    <Style TargetType="{x:Type ComboBox}" BasedOn="{StaticResource MaterialDesignOutlinedComboBox}">
        <Setter Property="Margin" Value="0,4,0,0" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="ToolTip" Value="请选择或输入该项" />
        <Setter Property="materialDesign:HintAssist.FloatingScale" Value="0.74" />
        <Setter Property="materialDesign:HintAssist.IsFloating" Value="True" />
    </Style>

    <Style TargetType="{x:Type DatePicker}" BasedOn="{StaticResource MaterialDesignOutlinedDatePicker}">
        <Setter Property="Margin" Value="0,4,0,0" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="ToolTip" Value="请选择日期" />
        <Setter Property="materialDesign:HintAssist.FloatingScale" Value="0.74" />
        <Setter Property="materialDesign:HintAssist.IsFloating" Value="True" />
    </Style>

    <Style TargetType="{x:Type DataGrid}" BasedOn="{StaticResource MaterialDesignDataGrid}">
        <Setter Property="AutoGenerateColumns" Value="True" />
        <Setter Property="controls:MaterialDataGridColumns.UseBusinessColumns" Value="True" />
        <Setter Property="Background" Value="{DynamicResource TenderSurfaceBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TenderTextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource TenderStrokeBrush}" />
    </Style>

    <Style TargetType="{x:Type controls:InfoBar}">
        <Setter Property="Margin" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:InfoBar}">
                    <Border Padding="14,10"
                            Background="{TemplateBinding SeverityBackground}"
                            BorderBrush="{TemplateBinding SeverityForeground}"
                            BorderThickness="0"
                            CornerRadius="8"
                            Visibility="{Binding IsOpen, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Width="20"
                                                     Height="20"
                                                     Margin="0,1,10,0"
                                                     VerticalAlignment="Top"
                                                     Foreground="{TemplateBinding SeverityForeground}"
                                                     Kind="InformationOutline" />
                            <StackPanel Grid.Column="1">
                                <TextBlock FontWeight="SemiBold"
                                           Foreground="{TemplateBinding SeverityForeground}"
                                           Text="{TemplateBinding Title}" />
                                <TextBlock Margin="0,3,0,0"
                                           Text="{TemplateBinding Message}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:InfoBadge}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:InfoBadge}">
                    <Border Padding="9,4"
                            Background="{TemplateBinding BadgeBackground}"
                            CornerRadius="12">
                        <TextBlock FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{TemplateBinding BadgeForeground}"
                                   Text="{TemplateBinding Value}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
