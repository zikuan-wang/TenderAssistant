<Window x:Class="TenderAssistant.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="投标助手"
        Width="460"
        Height="900"
        MinWidth="390"
        MinHeight="720"
        Background="{DynamicResource TenderAppBackgroundBrush}"
        TextElement.Foreground="{DynamicResource TenderTextBrush}"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <materialDesign:Card Grid.Row="0"
                             Margin="10,10,10,6"
                             Padding="12"
                             Background="{DynamicResource TenderSurfaceBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Width="38"
                        Height="38"
                        CornerRadius="10"
                        Background="{DynamicResource TenderPrimaryBrush}">
                    <materialDesign:PackIcon Width="22"
                                             Height="22"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Foreground="White"
                                             Kind="FileDocumentEditOutline" />
                </Border>
                <StackPanel Grid.Column="1"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center">
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="投标助手" />
                    <TextBlock FontSize="12"
                               Foreground="{DynamicResource TenderSubtleTextBrush}"
                               Text="{Binding LicenseStatus}" />
                </StackPanel>
                <StackPanel Grid.Column="2"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                    <TextBlock Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{DynamicResource TenderSubtleTextBrush}"
                               Text="{Binding CurrentUser}" />
                    <Button Width="34"
                            Height="34"
                            Style="{StaticResource MaterialTransparentButtonStyle}"
                            ToolTip="关于助手"
                            Click="OnAboutClick">
                        <materialDesign:PackIcon Width="20"
                                                 Height="20"
                                                 Kind="InformationOutline" />
                    </Button>
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <TabControl x:Name="MainTabs"
                    Grid.Row="1"
                    Margin="10,0,10,6"
                    Style="{StaticResource MaterialDesignFilledTabControl}">
            <TabItem Header="标书">
                <Frame x:Name="BidAssistFrame"
                       NavigationUIVisibility="Hidden" />
            </TabItem>
            <TabItem Header="设置">
                <Frame x:Name="SettingsFrame"
                       NavigationUIVisibility="Hidden" />
            </TabItem>
            <TabItem x:Name="AboutTab"
                     Visibility="Collapsed">
                <Frame x:Name="AboutFrame"
                       NavigationUIVisibility="Hidden" />
            </TabItem>
        </TabControl>

        <Border Grid.Row="2"
                Margin="10,0,10,10"
                Padding="10,8"
                Background="{DynamicResource TenderSurfaceBrush}"
                BorderBrush="{DynamicResource TenderStrokeBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="{Binding TaskStatus.IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="120" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center"
                           Text="{Binding TaskStatus.Message}" />
                <ProgressBar Grid.Column="1"
                             Height="6"
                             VerticalAlignment="Center"
                             IsIndeterminate="True" />
            </Grid>
        </Border>
    </Grid>
</Window>
