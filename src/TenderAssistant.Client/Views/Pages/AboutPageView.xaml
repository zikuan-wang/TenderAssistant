<UserControl x:Class="TenderAssistant.Client.Views.Pages.AboutPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:infra="clr-namespace:TenderAssistant.Client.Infrastructure"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  CanContentScroll="False"
                  infra:MouseWheelScroll.IsEnabled="True">
        <StackPanel Margin="{StaticResource PageContentPadding}">
            <TextBlock FontSize="22"
                       FontWeight="SemiBold"
                       Text="关于助手" />
            <TextBlock Margin="0,4,0,14"
                       Opacity="0.72"
                       Text="投标助手是本地离线运行的标书资料插入辅助工具。"
                       TextWrapping="Wrap" />

            <materialDesign:Card>
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}"
                               Text="当前版本" />
                    <TextBlock Text="投标助手 本地离线版" />
                    <TextBlock Margin="0,6,0,0"
                               Text="版本：1.0.0" />
                    <TextBlock Margin="0,6,0,0"
                               Text=".NET 8 / WPF / Material Design in XAML" />
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card>
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}"
                               Text="版权信息" />
                    <TextBlock Text="Copyright © 2026 zikuan wang. All rights reserved." />
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card>
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}"
                               Text="功能范围" />
                    <TextBlock Text="标书辅助：读取本地技术、商务、资质文件库，插入到当前 Word/WPS 文档。" TextWrapping="Wrap" />
                    <TextBlock Margin="0,6,0,0" Text="离线授权：客户端导出申请文件，授权工具生成激活文件，客户端导入后激活。" TextWrapping="Wrap" />
                    <TextBlock Margin="0,6,0,0" Text="设置与日志：配置本地文件库、同步本地文件夹、维护操作日志。" TextWrapping="Wrap" />
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card>
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}"
                               Text="运行方式" />
                    <TextBlock Text="本软件不连接后端服务器，不进行远程同步，所有资料和授权文件均在本机或用户指定文件夹内处理。" TextWrapping="Wrap" />
                </StackPanel>
            </materialDesign:Card>
        </StackPanel>
    </ScrollViewer>
</UserControl>
