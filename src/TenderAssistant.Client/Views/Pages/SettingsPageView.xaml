<UserControl x:Class="TenderAssistant.Client.Views.Pages.SettingsPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:infra="clr-namespace:TenderAssistant.Client.Infrastructure"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  CanContentScroll="False"
                  infra:MouseWheelScroll.IsEnabled="True">
        <StackPanel Margin="{StaticResource PageContentPadding}">
            <TextBlock FontSize="22"
                       FontWeight="SemiBold"
                       Text="设置与日志" />
            <TextBlock Margin="0,2,0,8"
                       Opacity="0.72"
                       Text="配置本地文件库、离线授权和操作日志。软件全程离线运行。"
                       TextWrapping="Wrap" />

            <materialDesign:Card>
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}"
                               Text="离线授权" />
                    <TextBlock Opacity="0.68"
                               Text="{Binding LicenseStatus}"
                               TextWrapping="Wrap" />
                    <TextBox Margin="0,8,0,0"
                             materialDesign:HintAssist.Hint="申请人"
                             Text="{Binding ApplicantName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox Margin="0,6,0,0"
                             IsReadOnly="True"
                             materialDesign:HintAssist.Hint="设备指纹"
                             Text="{Binding DeviceFingerprint, Mode=OneWay}" />
                    <WrapPanel Margin="0,8,0,0"
                               HorizontalAlignment="Right">
                        <Button Style="{StaticResource MaterialSecondaryButtonStyle}"
                                Command="{Binding ExportLicenseRequestCommand}"
                                Content="导出授权申请" />
                        <Button Margin="8,0,0,0"
                                Style="{StaticResource MaterialPrimaryButtonStyle}"
                                Command="{Binding ImportActivationCommand}"
                                Content="导入激活文件" />
                    </WrapPanel>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card>
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}"
                               Text="本地文件库" />
                    <TextBlock Opacity="0.66"
                               Text="将源文件库的技术文件、商务文件、资质文件同步到本地文件库。"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,8,0,2"
                               Text="源文件库" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox VerticalAlignment="Center"
                                 Text="{Binding SourceFileLibraryPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1"
                                Width="72"
                                Margin="8,0,0,0"
                                Style="{StaticResource MaterialSecondaryButtonStyle}"
                                Command="{Binding BrowseSourceFileLibraryCommand}"
                                Content="选择" />
                    </Grid>
                    <TextBlock Margin="0,8,0,2"
                               Text="本地文件库" />
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox VerticalAlignment="Center"
                                 Text="{Binding FileLibraryCachePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1"
                                Width="72"
                                Margin="8,0,0,0"
                                Style="{StaticResource MaterialSecondaryButtonStyle}"
                                Command="{Binding BrowseFileLibraryCacheCommand}"
                                Content="选择" />
                    </Grid>
                    <Button Margin="0,8,0,0"
                            HorizontalAlignment="Right"
                            Style="{StaticResource MaterialPrimaryButtonStyle}"
                            Command="{Binding SyncFileLibraryCommand}"
                            Content="同步文件库" />
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="150" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="APP 主题" />
                        <TextBlock Opacity="0.66"
                                   Text="切换浅色或深色显示。" />
                    </StackPanel>
                    <ComboBox Grid.Column="1"
                              VerticalAlignment="Center"
                              DisplayMemberPath="Name"
                              ItemsSource="{Binding ThemeOptions}"
                              SelectedValue="{Binding SelectedTheme, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="Theme" />
                </Grid>
            </materialDesign:Card>

            <materialDesign:Card>
                <StackPanel>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock DockPanel.Dock="Left"
                                   Style="{StaticResource SectionTitleStyle}"
                                   Text="操作日志" />
                        <WrapPanel DockPanel.Dock="Right"
                                   HorizontalAlignment="Right">
                            <Button Style="{StaticResource MaterialSecondaryButtonStyle}"
                                    Command="{Binding ArchiveCommand}"
                                    Content="归档" />
                            <Button Margin="6,0,0,0"
                                    Style="{StaticResource MaterialSecondaryButtonStyle}"
                                    Command="{Binding DownloadCommand}"
                                    Content="下载" />
                            <Button Margin="6,0,0,0"
                                    Style="{StaticResource MaterialDangerButtonStyle}"
                                    Command="{Binding ClearCommand}"
                                    Content="清除" />
                        </WrapPanel>
                    </DockPanel>
                    <TextBlock Margin="0,0,0,6"
                               Opacity="0.66"
                               Text="{Binding StatusMessage}" />
                    <DataGrid Height="220"
                              AutoGenerateColumns="True"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              ItemsSource="{Binding Logs}" />
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card>
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}"
                               Text="归档文件" />
                    <DataGrid Height="140"
                              Margin="0,6,0,0"
                              AutoGenerateColumns="True"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              ItemsSource="{Binding Archives}" />
                </StackPanel>
            </materialDesign:Card>
        </StackPanel>
    </ScrollViewer>
</UserControl>
