<UserControl x:Class="TenderAssistant.Client.Views.Pages.BidAssistPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:infra="clr-namespace:TenderAssistant.Client.Infrastructure"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  CanContentScroll="False"
                  infra:MouseWheelScroll.IsEnabled="True">
        <StackPanel Margin="{StaticResource PageContentPadding}">
            <TextBlock FontSize="22"
                       FontWeight="SemiBold"
                       Text="标书辅助" />
            <TextBlock Margin="0,2,0,8"
                       Opacity="0.72"
                       Text="竖版辅助工具模式：从本地文件库或自定义文件中选择资料，插入到当前 Word/WPS 光标位置。"
                       TextWrapping="Wrap" />

            <materialDesign:Card>
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="本地文件" />
                        <Button Grid.Column="1"
                                Width="72"
                                Margin="8,0,0,0"
                                Padding="8,4"
                                Command="{Binding RefreshCommand}"
                                Content="刷新" />
                    </Grid>

                    <ComboBox Margin="0,6,0,0"
                              DisplayMemberPath="Name"
                              ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding SelectedCategory, Mode=TwoWay}" />
                    <TextBox Margin="0,6,0,0"
                             materialDesign:HintAssist.Hint="文件名筛选"
                             Text="{Binding FileNameFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <WrapPanel Margin="0,6,0,0"
                               HorizontalAlignment="Right">
                        <Button Style="{StaticResource MaterialSecondaryButtonStyle}"
                                Command="{Binding ImportCustomCommand}"
                                Content="自定义导入"
                                Visibility="{Binding IsCustomCategorySelected, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <Button Margin="8,0,0,0"
                                Style="{StaticResource MaterialSecondaryButtonStyle}"
                                Command="{Binding ClearCustomCommand}"
                                Content="清除列表"
                                Visibility="{Binding IsCustomCategorySelected, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </WrapPanel>

                    <DataGrid Height="210"
                              Margin="0,8,0,0"
                              AutoGenerateColumns="True"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ItemsSource="{Binding Files}"
                              SelectedItem="{Binding SelectedFile, Mode=TwoWay}" />
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card>
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}"
                               Text="文件预览" />
                    <Grid Height="190">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      infra:MouseWheelScroll.IsEnabled="True">
                            <ScrollViewer.Style>
                                <Style TargetType="{x:Type ScrollViewer}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasImagePreview}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ScrollViewer.Style>
                            <TextBlock Text="{Binding PreviewText}"
                                       TextWrapping="Wrap" />
                        </ScrollViewer>
                        <Border ClipToBounds="True">
                            <Border.Style>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasImagePreview}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Image Source="{Binding PreviewImagePath}"
                                   Stretch="Uniform" />
                        </Border>
                    </Grid>
                    <TextBlock Margin="0,6,0,0"
                               FontSize="12"
                               Opacity="0.66"
                               Text="{Binding SelectedFilePath}"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card>
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}"
                               Text="插入设置" />
                    <ComboBox Margin="0,6,0,0"
                              materialDesign:HintAssist.Hint="PDF 质量"
                              DisplayMemberPath="DisplayName"
                              ItemsSource="{Binding PdfQualityOptions}"
                              SelectedItem="{Binding SelectedPdfQuality, Mode=TwoWay}" />
                    <ComboBox Margin="0,6,0,0"
                              materialDesign:HintAssist.Hint="Word 插入方式"
                              DisplayMemberPath="Name"
                              ItemsSource="{Binding WordInsertModeOptions}"
                              SelectedItem="{Binding SelectedWordInsertMode, Mode=TwoWay}" />
                    <CheckBox Margin="0,6,0,0"
                              Content="PDF 每页分页"
                              IsChecked="{Binding PageBreakBetweenPdfPages, Mode=TwoWay}" />
                    <TextBox Margin="0,6,0,0"
                             materialDesign:HintAssist.Hint="图片/PDF 宽度 cm"
                             Text="{Binding InsertImageWidthCentimeters, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=0.#}" />
                    <WrapPanel Margin="0,8,0,0"
                               HorizontalAlignment="Right">
                        <Button Style="{StaticResource MaterialSecondaryButtonStyle}"
                                Command="{Binding OpenSourceCommand}"
                                Content="打开" />
                        <Button Margin="6,0,0,0"
                                Style="{StaticResource MaterialSecondaryButtonStyle}"
                                Command="{Binding OpenLocalFolderCommand}"
                                Content="位置" />
                        <Button Margin="6,0,0,0"
                                Style="{StaticResource MaterialDangerButtonStyle}"
                                Command="{Binding DeleteLocalCacheCommand}"
                                Content="删除" />
                        <Button Margin="6,0,0,0"
                                Style="{StaticResource MaterialPrimaryButtonStyle}"
                                Command="{Binding InsertSelectedCommand}"
                                Content="插入" />
                    </WrapPanel>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card>
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}"
                               Text="插入日志" />
                    <DataGrid Height="150"
                              Margin="0,6,0,0"
                              AutoGenerateColumns="True"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ItemsSource="{Binding InsertLogs}" />
                </StackPanel>
            </materialDesign:Card>
        </StackPanel>
    </ScrollViewer>
</UserControl>
