<Window x:Class="TenderAssistant.Authorizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="投标助手离线授权工具"
        Width="520"
        Height="520"
        MinWidth="460"
        MinHeight="460"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock FontSize="22"
                       FontWeight="SemiBold"
                       Text="离线授权工具" />
            <TextBlock Margin="0,6,0,16"
                       Text="导入客户端授权申请文件，选择授权到期时间后生成激活文件。"
                       TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Row="1">
            <Button Width="160"
                    HorizontalAlignment="Left"
                    Click="OnImportRequestClick"
                    Content="导入申请文件" />
            <TextBlock Margin="0,14,0,4"
                       FontWeight="SemiBold"
                       Text="申请信息" />
            <TextBox Height="130"
                     IsReadOnly="True"
                     Text="{Binding RequestSummary, Mode=OneWay}"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" />

            <TextBlock Margin="0,14,0,4"
                       Text="授权到期时间" />
            <DatePicker SelectedDate="{Binding ExpiresAt, Mode=TwoWay}" />

            <TextBlock Margin="0,14,0,4"
                       Text="授权版本" />
            <TextBox Text="{Binding Edition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <StackPanel Grid.Row="2">
            <TextBlock Margin="0,0,0,10"
                       Foreground="#666666"
                       Text="{Binding StatusMessage}"
                       TextWrapping="Wrap" />
            <Button Height="36"
                    HorizontalAlignment="Stretch"
                    Click="OnGenerateLicenseClick"
                    Content="生成激活文件" />
        </StackPanel>
    </Grid>
</Window>
